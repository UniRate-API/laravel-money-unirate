{
    "name": "unirate-api/laravel-money",
    "description": "UniRate exchange-rate bridge for akaunting/laravel-money — automatic rate fetching, caching, and conversion.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "money",
        "currency",
        "exchange-rates",
        "forex",
        "unirate",
        "akaunting",
        "currency-converter"
    ],
    "homepage": "https://github.com/UniRate-API/laravel-money-unirate",
    "authors": [
        {
            "name": "Unirate Team",
            "homepage": "https://unirateapi.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "akaunting/laravel-money": "^5.0 || ^6.0",
        "illuminate/cache": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "UniRate\\LaravelMoney\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UniRate\\LaravelMoney\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "UniRate\\LaravelMoney\\UniRateServiceProvider"
            ],
            "aliases": {
                "UniRate": "UniRate\\LaravelMoney\\Facades\\UniRate"
            }
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
